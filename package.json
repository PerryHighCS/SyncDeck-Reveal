{
  "name": "syncdeck-reveal-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint reveal-iframe-sync.js reveal-storyboard.js syncdeck-bootstrap.js src rollup.config.mjs scripts test",
    "test": "npm run lint && node scripts/run-playwright.mjs",
    "test:headed": "node scripts/run-playwright.mjs --headed",
    "build": "node scripts/build-runtime.mjs",
    "build:check": "node scripts/build-check.mjs",
    "ship": "npm run test && npm run build && npm run build:check"
  },
  "dependencies": {
    "reveal.js": "5.1.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "rollup": "^4.52.5",
    "rollup-plugin-postcss": "^4.0.2"
  }
}
